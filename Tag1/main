#include <stdio.h>
#include <complex.h>
int main (void) {
    float complex fc = 2.0 + 3.0*I;     // 4 Byts
    printf("sizeof(float) : %zu\n", sizeof(float));
    // 8 Bytes
    printf("sizeof(float complex) : %zu\n", sizeof(float complex));
    // Ausgabe
    printf("%f + %fi\n", crealf(fc), cimagf(fc));
    return 0;
}
